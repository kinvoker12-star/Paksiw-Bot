{
  "version": 2,
  "builds": [
    {
      "src": "paksiw_site/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "paksiw_site/wsgi.py"
    }
  ],
  "installCommand": "bash build.sh"
}